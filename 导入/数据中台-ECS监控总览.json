          "expr": "count((min by(instance,name,iid) (label_replace(clamp_min(clamp_max(100 - ((100 * (1 - avg by(instance,name,iid) (rate(node_cpu_seconds_total{group=~\"$group\",mode=\"idle\"}[3m])))) - 80) * 5, 100), 0), \"health_part\", \"cpu\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((100 * (1 - max by(instance,name,iid) (node_memory_MemAvailable_bytes{group=~\"$group\"}) / max by(instance,name,iid) (node_memory_MemTotal_bytes{group=~\"$group\"}))) - 80) * 5, 100), 0), \"health_part\", \"memory\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((max by(instance,name,iid) ((node_filesystem_size_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"} - node_filesystem_free_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"}) * 100 / node_filesystem_size_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"})) - 80) * 5, 100), 0), \"health_part\", \"filesystem\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((max by(instance,name,iid) (100 * rate(node_disk_io_time_seconds_total{group=~\"$group\",device!~\"loop.*|ram.*|fd.*|sr.*\"}[3m]))) - 80) * 5, 100), 0), \"health_part\", \"disk_io\", \"instance\", \".*\")) * on(instance) group_left() ((max by(instance) (up{group=~\"$group\"}) or max by(instance) (node_uname_info{group=~\"$group\"})))) < 80) or vector(0)",

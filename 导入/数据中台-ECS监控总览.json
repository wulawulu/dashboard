          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "min by(instance,name,iid) (node_filesystem_avail_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "最小可用空间",
          "range": false,
          "refId": "F"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (100 * rate(node_disk_io_time_seconds_total{group=~\"$group\",device!~\"loop.*|ram.*|fd.*|sr.*\"}[3m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "磁盘繁忙度",
          "range": false,
          "refId": "G"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (node_load5{group=~\"$group\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "5分钟负载",
          "range": false,
          "refId": "H"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (node_procs_blocked{group=~\"$group\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "阻塞进程",
          "range": false,
          "refId": "I"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "sum by(instance,name,iid) (rate(node_disk_read_bytes_total{group=~\"$group\",device!~\"loop.*|ram.*|fd.*|sr.*\"}[3m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "磁盘读取",
          "range": false,
          "refId": "J"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "sum by(instance,name,iid) (rate(node_disk_written_bytes_total{group=~\"$group\",device!~\"loop.*|ram.*|fd.*|sr.*\"}[3m]))",
          "format": "table",
          "instant": true,
          "legendFormat": "磁盘写入",
          "range": false,
          "refId": "K"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (rate(node_network_receive_bytes_total{group=~\"$group\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*|cni.*\"}[3m]) * 8)",
          "format": "table",
          "instant": true,
          "legendFormat": "下载带宽",
          "range": false,
          "refId": "L"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (rate(node_network_transmit_bytes_total{group=~\"$group\",device!~\"tap.*|veth.*|br.*|docker.*|virbr.*|lo.*|cni.*\"}[3m]) * 8)",
          "format": "table",
          "instant": true,
          "legendFormat": "上传带宽",
          "range": false,
          "refId": "M"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (node_netstat_Tcp_CurrEstab{group=~\"$group\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "TCP连接数",
          "range": false,
          "refId": "N"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (node_sockstat_TCP_tw{group=~\"$group\"})",
          "format": "table",
          "instant": true,
          "legendFormat": "TIME_WAIT连接数",
          "range": false,
          "refId": "O"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "max by(instance,name,iid) (floor((time() - node_boot_time_seconds{group=~\"$group\"}) / 86400))",
          "format": "table",
          "instant": true,
          "legendFormat": "启动天数",
          "range": false,
          "refId": "P"
        },
        {
          "datasource": "Prometheus-tenant",
          "editorMode": "code",
          "expr": "min by(instance,name,iid) (label_replace(clamp_min(clamp_max(100 - ((100 * (1 - avg by(instance,name,iid) (rate(node_cpu_seconds_total{group=~\"$group\",mode=\"idle\"}[3m])))) - 80) * 5, 100), 0), \"health_part\", \"cpu\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((100 * (1 - max by(instance,name,iid) (node_memory_MemAvailable_bytes{group=~\"$group\"}) / max by(instance,name,iid) (node_memory_MemTotal_bytes{group=~\"$group\"}))) - 80) * 5, 100), 0), \"health_part\", \"memory\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((max by(instance,name,iid) ((node_filesystem_size_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"} - node_filesystem_free_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"}) * 100 / node_filesystem_size_bytes{group=~\"$group\",fstype=~\"ext.?|xfs|nfs\",mountpoint!~\".*pod.*\"})) - 80) * 5, 100), 0), \"health_part\", \"filesystem\", \"instance\", \".*\") or label_replace(clamp_min(clamp_max(100 - ((max by(instance,name,iid) (100 * rate(node_disk_io_time_seconds_total{group=~\"$group\",device!~\"loop.*|ram.*|fd.*|sr.*\"}[3m]))) - 80) * 5, 100), 0), \"health_part\", \"disk_io\", \"instance\", \".*\")) * on(instance) group_left() ((max by(instance) (up{group=~\"$group\"}) or max by(instance) (node_uname_info{group=~\"$group\"})))",
          "format": "table",
          "instant": true,
          "legendFormat": "健康值",
          "range": false,
          "refId": "Q"
        }
      ],
